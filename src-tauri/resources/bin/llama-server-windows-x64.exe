#!/bin/bash
# 模拟 llama-server（开发用）

PORT=8043
MODEL=""
GPU_LAYERS="99"

while [[ $# -gt 0 ]]; do
  case $1 in
    --model)
      MODEL="$2"
      shift 2
      ;;
    --port)
      PORT="$2"
      shift 2
      ;;
    --n-gpu-layers)
      GPU_LAYERS="$2"
      shift 2
      ;;
    --help)
      echo "usage: llama-server [options]"
      echo ""
      echo "options:"
      echo "  --model <path>           model path"
      echo "  --port <port>            server port (default: 8000)"
      echo "  --n-gpu-layers <n>       GPU layers (default: 0)"
      exit 0
      ;;
    *)
      shift
      ;;
  esac
done

echo "Mock llama-server starting..."
echo "Model: $MODEL"
echo "Port: $PORT"
echo "GPU Layers: $GPU_LAYERS"
echo ""
echo "Server listening on http://localhost:$PORT"
echo ""
echo "Press Ctrl+C to stop"

# 模拟运行（保持进程活跃）
trap "echo 'Server stopped'" EXIT
while true; do
  sleep 10
done
