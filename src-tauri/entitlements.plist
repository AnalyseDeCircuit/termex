<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Hardened runtime — required for Developer ID signing + notarization. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <false/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Network — SSH / SFTP / AI provider calls / appcast fetch -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <false/>

  <!-- File access — user-selected SFTP uploads / downloads / key imports -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
  <key>com.apple.security.files.downloads.read-write</key>
  <true/>

  <!-- NOTE: do NOT add `keychain-access-groups` here. `$(AppIdentifierPrefix)`
       is an Xcode-only build variable that codesign does not expand, so a literal
       "$(AppIdentifierPrefix)..." entitlement gets embedded and AMFI kills the
       process at launch with SIGKILL. The app already gets its default keychain
       access group (`<team-id>.<bundle-id>`) from being signed, which is what
       the `keyring` crate uses for SSH/AI credential storage. -->
</dict>
</plist>
